# =====================================================================
# Fig 1: Histograma de Errores
plt.figure(figsize=(7, 4))
plt.hist(errores, bins=15, color='steelblue', edgecolor='black', alpha=0.8)
plt.axvline(mean_err, color='red', linestyle='--', label=f'Mean: {mean_err:.2f}%')
plt.title(f'Errors Histogram - {NOMBRE_TAXON}', fontsize=11, fontweight='bold')
plt.xlabel('Relative Error (%)')
plt.ylabel('Frecuency')
plt.grid(True, linestyle=':', alpha=0.6)
plt.legend()
